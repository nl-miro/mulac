# Database connection URL for the test_app_todo application
# Format: postgres://username:password@host:port/database
#
# To run tests locally, you'll need a PostgreSQL database.
# If using Docker, you can start one with:
#   docker run --name postgres -e POSTGRES_PASSWORD=postgres -d -p 5432:5432 postgres:latest
#   docker exec postgres createdb -U postgres test_app_todo
#
DATABASE_URL=postgres://postgres:postgres@localhost:5432/test_app_todo

# AMQP connection URL (used for message broker integration if applicable)
# Format: amqp://username:password@host:port/vhost
# If using Docker, you can start RabbitMQ with:
#   docker run --name rabbitmq -d -p 5672:5672 -p 15672:15672 rabbitmq:3-management
#
AMQP_URL=amqp://guest:guest@localhost:5672/%2F
